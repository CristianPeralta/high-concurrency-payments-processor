    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/jest": "29.5.0",
    "@types/node": "20.0.0",
    "@types/pg": "8.10.9",
    "jest": "29.7.0",
    "ts-jest": "29.1.0",
    "ts-node": "10.9.2",
    "tsx": "4.20.6",
    "typescript": "5.0.0"
  }
}
